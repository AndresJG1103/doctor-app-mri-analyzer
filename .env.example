# =============================================================================
# MRI Report API - Environment Variables
# =============================================================================
# Copy this file to .env and modify as needed

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
PROJECT_NAME=MRI Report API
VERSION=0.1.0
API_V1_STR=/api/v1
HOST=0.0.0.0
PORT=8000

# CORS - comma separated origins or * for all
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# FastSurfer Configuration
# -----------------------------------------------------------------------------
# Docker image to use for FastSurfer
FASTSURFER_IMAGE=deepmi/fastsurfer:latest

# GPU Configuration
# Set to true to enable GPU processing (requires NVIDIA GPU and drivers)
FASTSURFER_USE_GPU=false

# Device to use: cpu, cuda, cuda:0, cuda:1, etc.
FASTSURFER_DEVICE=cpu

# Number of threads for processing
FASTSURFER_THREADS=4

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
# Directory for uploaded MRI files
DATA_INPUT_DIR=/data/input

# Directory for FastSurfer output
DATA_OUTPUT_DIR=/data/output

# Path to FreeSurfer license file (required for surface reconstruction)
FREESURFER_LICENSE_PATH=/data/licenses/license.txt

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum upload size in bytes (default: 500MB)
MAX_UPLOAD_SIZE=524288000

# Allowed file extensions (comma separated)
ALLOWED_EXTENSIONS=.nii,.nii.gz,.mgz

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Maximum concurrent jobs
MAX_CONCURRENT_JOBS=2

# Job timeout in seconds (default: 2 hours)
JOB_TIMEOUT=7200

# IMPORTANT: Set this to the absolute path of your data directory on the HOST machine
# This is required for Docker-in-Docker volume mounting
# Example Linux: /home/user/mri_report/data
# Example Windows: C:/Users/user/mri_report/data (use forward slashes)
HOST_DATA_PATH=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# HTTP Basic Auth credentials (CHANGE IN PRODUCTION!)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
