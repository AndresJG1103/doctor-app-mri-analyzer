# =============================================================================
# MRI Report API - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# -----------------------------------------------------------------------------
# IDEs and Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Type Checking
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# MRI Data (Large Files)
# -----------------------------------------------------------------------------
data/input/*
data/output/*
data/temp/*
!data/input/.gitkeep
!data/output/.gitkeep
*.nii
*.nii.gz
*.mgz
*.mgh

# -----------------------------------------------------------------------------
# FastSurfer Outputs
# -----------------------------------------------------------------------------
fastsurfer_output/
subjects/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.tar

# -----------------------------------------------------------------------------
# FreeSurfer License (Keep secure!)
# -----------------------------------------------------------------------------
data/licenses/*
!data/licenses/.gitkeep

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# Project Specific
# -----------------------------------------------------------------------------
create_dirs.bat
create_dirs.py
init_project.py
setup.sh
setup_wsl.bat

# -----------------------------------------------------------------------------
# Agents
# -----------------------------------------------------------------------------
.agents/